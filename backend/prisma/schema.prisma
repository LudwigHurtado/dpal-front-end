// DPAL Help Center — Prisma Schema
// Database: Supabase PostgreSQL
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ReportStatus {
  submitted
  under_review
  awaiting_contact
  awaiting_documents
  assigned
  in_progress
  referred_out
  resolved
  closed
  rejected
  duplicate
}

enum ReportUrgency {
  low
  normal
  high
  urgent
  emergency
}

enum ReportSource {
  web
  mobile
  admin
  phone_intake
  api
}

enum Visibility {
  private
  internal
  public_redacted
}

enum NoteType {
  internal
  follow_up
  resolution
  contact_log
}

enum ContactMethod {
  email
  phone
  text
  any
}

// ─── Main report record ───────────────────────────────────────────────────────

model HelpReport {
  id                    String        @id @default(cuid())
  reportNumber          String        @unique // HC-2026-000001
  userId                String?       // nullable for anonymous

  category              String
  subcategory           String?
  tags                  String[]      @default([])

  title                 String
  description           String

  urgency               ReportUrgency @default(normal)
  status                ReportStatus  @default(submitted)
  source                ReportSource  @default(web)
  visibility            Visibility    @default(private)

  isAnonymous           Boolean       @default(false)
  needsImmediateResponse Boolean      @default(false)
  isDuplicate           Boolean       @default(false)
  duplicateOfId         String?

  language              String        @default("en")

  occurredAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // ── Relations ──
  contact               HelpReportContact?
  location              HelpReportLocation?
  attachments           HelpReportAttachment[]
  statusHistory         HelpReportStatusHistory[]
  notes                 HelpReportNote[]
  assignments           HelpReportAssignment[]

  @@map("help_reports")
  @@index([status])
  @@index([urgency])
  @@index([category])
  @@index([createdAt])
  @@index([userId])
}

// ─── Contact details ──────────────────────────────────────────────────────────

model HelpReportContact {
  id                    String  @id @default(cuid())
  reportId              String  @unique
  report                HelpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  fullName              String?
  phone                 String?
  email                 String?
  preferredContactMethod ContactMethod @default(email)
  safeToCall            Boolean @default(true)
  safeToText            Boolean @default(true)

  @@map("help_report_contacts")
}

// ─── Location details ─────────────────────────────────────────────────────────

model HelpReportLocation {
  id                    String  @id @default(cuid())
  reportId              String  @unique
  report                HelpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  country               String?
  stateRegion           String?
  city                  String?
  address               String?
  latitude              Float?
  longitude             Float?
  locationNotes         String?

  @@map("help_report_locations")
}

// ─── File attachments ─────────────────────────────────────────────────────────

model HelpReportAttachment {
  id                    String  @id @default(cuid())
  reportId              String
  report                HelpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  filePath              String  // Supabase Storage path
  publicUrl             String? // Public or signed URL
  fileName              String
  fileType              String
  fileSizeByes          Int?
  uploadedBy            String?

  createdAt             DateTime @default(now())

  @@map("help_report_attachments")
  @@index([reportId])
}

// ─── Status change history ────────────────────────────────────────────────────

model HelpReportStatusHistory {
  id                    String       @id @default(cuid())
  reportId              String
  report                HelpReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  oldStatus             ReportStatus?
  newStatus             ReportStatus
  changedBy             String       // user id or "system"
  reason                String?

  createdAt             DateTime     @default(now())

  @@map("help_report_status_history")
  @@index([reportId])
}

// ─── Internal notes ───────────────────────────────────────────────────────────

model HelpReportNote {
  id                    String    @id @default(cuid())
  reportId              String
  report                HelpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  authorId              String    // admin user id
  noteType              NoteType  @default(internal)
  body                  String

  createdAt             DateTime  @default(now())

  @@map("help_report_notes")
  @@index([reportId])
}

// ─── Assignments ──────────────────────────────────────────────────────────────

model HelpReportAssignment {
  id                    String    @id @default(cuid())
  reportId              String
  report                HelpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  assignedTo            String    // admin/staff user id
  assignedBy            String
  team                  String?
  assignedAt            DateTime  @default(now())

  @@map("help_report_assignments")
  @@index([reportId])
  @@index([assignedTo])
}

// ─── Counter table for sequential report numbers ──────────────────────────────

model ReportCounter {
  id                    Int      @id @default(1)
  lastNumber            Int      @default(0)

  @@map("report_counters")
}

enum ResolutionStatus {
  filed
  verified
  escalated
  responded
  corrected
  resolved
  ignored
  failed_delivery
  disputed
}

enum ResolutionEventType {
  case_filed
  case_verified
  case_escalated
  agency_responded
  correction_submitted
  case_resolved
  case_ignored
  route_dispatch_attempted
  route_dispatch_delivered
  route_dispatch_failed
  reward_issued
}

enum ResolutionRouteStatus {
  pending
  processing
  delivered
  failed
}

model ResolutionCase {
  id                 String            @id @default(cuid())
  caseId             String            @unique
  reportId           String?
  validatorNodeId    String?
  title              String
  category           String
  location           String
  severity           String
  status             ResolutionStatus  @default(filed)
  entity             String?
  reporter           String?
  verifier           String?
  resolutionScore    Int               @default(0)
  responseSlaHours   Int               @default(48)
  summary            String?
  publicImpact       String?
  nextAction         String?
  walletAddress      String?
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  events             ResolutionEvent[]
  routes             ResolutionRoute[]
  artifacts          ResolutionArtifact[]

  @@map("resolution_cases")
  @@index([status, updatedAt])
}

model ResolutionEvent {
  id                 String               @id @default(cuid())
  caseRefId          String
  caseRef            ResolutionCase       @relation(fields: [caseRefId], references: [id], onDelete: Cascade)
  eventType          ResolutionEventType
  actor              String
  note               String?
  payload            Json?
  createdAt          DateTime             @default(now())

  @@map("resolution_events")
  @@index([caseRefId, createdAt])
}

model ResolutionRoute {
  id                 String               @id @default(cuid())
  caseRefId          String
  caseRef            ResolutionCase       @relation(fields: [caseRefId], references: [id], onDelete: Cascade)
  destination        String
  channel            String
  target             String?
  status             ResolutionRouteStatus @default(pending)
  attemptCount       Int                  @default(0)
  maxAttempts        Int                  @default(5)
  nextAttemptAt      DateTime             @default(now())
  lastError          String?
  deliveredAt        DateTime?
  metadata           Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@map("resolution_routes")
  @@index([status, nextAttemptAt])
  @@index([caseRefId])
}

model ResolutionArtifact {
  id                 String               @id @default(cuid())
  caseRefId          String
  caseRef            ResolutionCase       @relation(fields: [caseRefId], references: [id], onDelete: Cascade)
  kind               String
  title              String
  url                String?
  sha256             String?
  uploadedBy         String?
  metadata           Json?
  createdAt          DateTime             @default(now())

  @@map("resolution_artifacts")
  @@index([caseRefId, createdAt])
}

model RewardWallet {
  id                 String               @id @default(cuid())
  walletAddress      String               @unique
  balanceCoins       Int                  @default(0)
  updatedAt          DateTime             @updatedAt
  createdAt          DateTime             @default(now())
  entries            RewardLedgerEntry[]

  @@map("reward_wallets")
}

model RewardLedgerEntry {
  id                 String               @id @default(cuid())
  walletId           String
  wallet             RewardWallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  caseId             String?
  amountCoins        Int
  reason             String
  source             String?
  metadata           Json?
  createdAt          DateTime             @default(now())

  @@map("reward_ledger_entries")
  @@index([walletId, createdAt])
}

// ─── DPAL app users (JWT + bcrypt; production identity layer) ───────────────

enum DpalAccountStatus {
  active
  pending_verification
  suspended
  banned
}

enum DpalOnlineStatus {
  offline
  online
  away
}

enum DpalUserRole {
  standard
  moderator
  admin
  validator
  support_agent
}

enum EmissionsAuditRiskLevel {
  low
  medium
  high
  needs_more_data
}

enum EmissionsAuditLedgerStatus {
  not_connected
  pending
  linked
  exported
  failed
}

enum CarbAuditRiskLevel {
  low
  medium
  high
  needs_more_data
}

enum HazardousWasteAuditRiskLevel {
  low
  medium
  high
  needs_more_data
}

model DpalUser {
  id           String @id @default(cuid())
  username     String @unique
  email        String @unique
  passwordHash String

  displayName String
  phone       String?
  location    String?

  profileImageUrl String?

  role            DpalUserRole      @default(standard)
  accountStatus   DpalAccountStatus @default(active)
  emailVerified   Boolean           @default(false)
  profileCompleted Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastLoginAt DateTime?
  lastSeenAt  DateTime?

  isOnline           Boolean          @default(false)
  onlineStatus       DpalOnlineStatus @default(offline)
  presenceUpdatedAt  DateTime?

  starterCredits Int @default(0)
  starterCoins   Int @default(0)
  heroCredits    Int @default(0)
  dpalCoins      Int @default(0)

  reputationScore Int @default(0)
  trustScore      Int @default(0)

  /// Optional JSON: starter badges, prefs, mission defaults metadata
  profileMetadata Json?

  refreshTokens RefreshToken[]
  emissionsAudits EmissionsAudit[]
  carbAudits      CarbAudit[]
  hazardousWasteAudits HazardousWasteAudit[]

  @@map("dpal_users")
  @@index([email])
  @@index([username])
  @@index([accountStatus])
  @@index([isOnline])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      DpalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([tokenHash])
  @@map("dpal_refresh_tokens")
}

model EmissionsAudit {
  id        String   @id @default(cuid())
  userId    String
  user      DpalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdBy      String
  lastModifiedBy String

  companyName    String
  facilityName   String
  industry       String
  jurisdiction   String
  legalFramework String

  locationLat      Float?
  locationLng      Float?
  polygonGeoJSON   Json?
  areaEstimate     Float?

  baselinePeriod Json
  currentPeriod  Json
  reportedData   Json?
  satelliteData  Json?
  productionData Json?
  calculations   Json
  confidence     Json

  adiScore   Float                    @default(0)
  riskLevel  EmissionsAuditRiskLevel  @default(low)

  legalContext          Json
  limitations           Json
  recommendedNextSteps  Json
  evidencePacket        Json?
  fullAudit             Json

  linkedReportId        String?
  linkedMissionId       String?
  linkedProjectId       String?
  linkedMRVProjectId    String?
  linkedEvidenceVaultId String?
  ledgerStatus          EmissionsAuditLedgerStatus @default(not_connected)

  version   Int        @default(1)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  versions EmissionsAuditVersion[]

  @@map("emissions_audits")
  @@index([userId, createdAt])
  @@index([companyName])
  @@index([facilityName])
  @@index([jurisdiction])
  @@index([adiScore])
  @@index([riskLevel])
  @@index([deletedAt])
}

model EmissionsAuditVersion {
  id         String         @id @default(cuid())
  auditId     String
  audit       EmissionsAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  version     Int
  modifiedBy  String
  changeSummary String?
  payload     Json
  createdAt   DateTime      @default(now())

  @@map("emissions_audit_versions")
  @@unique([auditId, version])
  @@index([auditId, createdAt])
}

model CarbAudit {
  id        String   @id @default(cuid())
  userId    String
  user      DpalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  facilityId   String
  facilityName String
  operatorName String
  city         String
  county       String
  state        String @default("California")
  latitude     Float?
  longitude    Float?
  sector       String

  baselineYear      Int
  currentYear       Int
  baselineEmissions Float
  currentEmissions  Float
  methaneBaseline   Float @default(0)
  methaneCurrent    Float @default(0)
  n2oBaseline       Float @default(0)
  n2oCurrent        Float @default(0)
  co2Baseline       Float @default(0)
  co2Current        Float @default(0)
  calculatedReductionPct Float?
  companyClaimText  String?
  claimReductionPct Float?
  claimGap          Float?
  discrepancyScore  Float?
  riskLevel         CarbAuditRiskLevel @default(needs_more_data)
  verificationStatus String

  dataSources      Json
  evidencePacket   Json?
  legalContext     Json
  limitations      Json
  recommendedNextSteps Json

  linkedMRVProjectId    String?
  linkedEvidenceVaultId String?
  linkedReportId        String?

  version   Int      @default(1)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carb_audits")
  @@index([userId, createdAt])
  @@index([facilityId])
  @@index([facilityName])
  @@index([county])
  @@index([riskLevel])
  @@index([deletedAt])
}

model HazardousWasteAudit {
  id        String   @id @default(cuid())
  userId    String
  user      DpalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  epaId         String
  facilityName  String
  operatorName  String
  city          String
  county        String
  state         String
  latitude      Float?
  longitude     Float?
  generatorStatus String
  permitStatus  String
  complianceStatus String
  correctiveActionStatus String

  baselineYear                Int
  currentYear                 Int
  baselineHazardousWasteTons  Float
  currentHazardousWasteTons   Float
  baselineManifestCount       Float
  currentManifestCount        Float
  violationsCount             Float @default(0)
  enforcementActionsCount     Float @default(0)
  wasteChangePct              Float?
  manifestChangePct           Float?
  complianceRiskScore         Float?
  integrityScore              Float?
  riskLevel                   HazardousWasteAuditRiskLevel @default(needs_more_data)

  claimText               String?
  claimAnalysisJson       Json
  verificationSummaryJson Json
  netCarbonRealityJson    Json?
  evidencePacketJson      Json?
  sourceMode              String
  dataSourcesJson         Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)
  deletedAt DateTime?

  linkedMRVProjectId    String?
  linkedEvidenceVaultId String?
  linkedReportId        String?

  @@map("hazardous_waste_audits")
  @@index([userId, createdAt])
  @@index([epaId])
  @@index([facilityName])
  @@index([riskLevel])
  @@index([deletedAt])
}
