# Copy to .env and fill in your Supabase credentials

# ─── Supabase Postgres (from Supabase dashboard → Settings → Database) ───────
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"
# Resolution dispatcher (Prisma polling): development requires ENABLE_RESOLUTION_DISPATCHER=true; production runs when DATABASE_URL is set unless ENABLE_RESOLUTION_DISPATCHER=false.
#ENABLE_RESOLUTION_DISPATCHER=true

# ─── Supabase project credentials ────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
SUPABASE_ANON_KEY="[ANON_KEY]"

# ─── Supabase Storage bucket for attachments ─────────────────────────────────
SUPABASE_STORAGE_BUCKET="help-attachments"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS — comma-separated list of allowed origins ──────────────────────────
# Backend accepts either FRONTEND_ORIGIN or CORS_ORIGINS (both are supported).
# Note: dpal-enterprise-dashboard.vercel.app and dpal-front-end.vercel.app are
# always allowed by built-in defaults in src/index.ts.
FRONTEND_ORIGIN="http://localhost:5173,http://localhost:3000"
# CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Admin secret (simple bearer token for admin endpoints in dev) ───────────
ADMIN_SECRET="change-this-in-production"

# ─── DPAL auth (JWT access + refresh tokens in PostgreSQL) ───────────────────
# Required for /api/auth/register|login|refresh|me|presence — use a long random string.
JWT_SECRET="replace-with-32-plus-random-chars-minimum"

# ─── Copernicus / Sentinel Hub backend-proxy credentials (server-only) ───────
COPERNICUS_ENABLED="true"
COPERNICUS_CLIENT_ID=""
COPERNICUS_CLIENT_SECRET=""
COPERNICUS_TOKEN_URL="https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token"
COPERNICUS_BASE_URL="https://services.sentinel-hub.com"

# ─── Earth Observation adapters (server-only) ─────────────────────────────────
EARTH_OBSERVATION_LIVE_ENABLED="false"
NASA_EARTHDATA_TOKEN=""
NASA_FIRMS_MAP_KEY=""

# ─── Hyperspectral Plastic Watch (PACE / EMIT CMR + drone connector, server-only) ─
# NASA CMR granule metadata (no fabricated spectral indices). PACE/EMIT require explicit enable flags + token.
NASA_CMR_BASE_URL="https://cmr.earthdata.nasa.gov/search"
DPAL_PACE_SPECTRAL_ENABLED="false"
DPAL_EMIT_L2A_ENABLED="false"
# Optional overrides for CMR short_name queries (defaults: PACE_OCI_L2_BGC, EMITL2ARFL)
# DPAL_PACE_CMR_SHORT_NAME="PACE_OCI_L2_BGC"
# DPAL_EMIT_CMR_SHORT_NAME="EMITL2ARFL"
# Drone validation connector (prepare-only endpoints; no secrets returned to clients)
DPAL_DRONE_VALIDATION_ENABLED="false"
DPAL_DRONE_PROVIDER_MODE="manual"
# DPAL_DRONE_PROVIDER_API_URL=""
# DPAL_DRONE_PROVIDER_API_KEY=""

# ─── CAD Trust API connector (server-only; GET /api/cadtrust/health probes live) ─
# When CADTRUST_SYNC_ENABLED=true, health calls GET {CADTRUST_API_BASE}/organizations with x-api-key.
CADTRUST_API_BASE=""
CADTRUST_API_KEY=""
CADTRUST_SYNC_ENABLED="false"

# ─── Global Forest Watch (Forest Integrity adapter, backend-only) ────────────
# Either GFW_API_KEY or GLOBAL_FOREST_WATCH_API_KEY enables the GFW lane.
# Never expose to the frontend. Missing key → not_configured (no crash).
GFW_API_KEY=""
GLOBAL_FOREST_WATCH_API_KEY=""
GFW_DATA_API_BASE="https://data-api.globalforestwatch.org"
# Optional: matches one of the `domains` your GFW key is registered for.
# When set, the backend sends `Origin` / `Referer` headers so GFW's API-key
# origin allowlist accepts the call (otherwise valid keys can return 401/403).
# Example: GFW_API_ORIGIN="https://web-production-a27b.up.railway.app"
GFW_API_ORIGIN=""

# Smoke script base override (default http://127.0.0.1:$PORT)
# FOREST_INTEGRITY_SMOKE_BASE="http://127.0.0.1:3001"

# Optional: default balances for new accounts (see src/config/starterDefaults.ts)
# DPAL_STARTER_CREDITS=1000
# DPAL_STARTER_COINS=500
# DPAL_STARTER_HERO_CREDITS=2745
# DPAL_STARTER_DPAL_COINS=100
# DPAL_STARTER_REPUTATION=10
# DPAL_STARTER_TRUST=50

# ─── USGS 3DEP / National Map elevation (public; no API key) ─────────────────
# USGS_3DEP_ENABLED=true
# USGS_3DEP_PROVIDER=USGS_3DEP
# USGS_3DEP_ELEVATION_POINT_QUERY=https://epqs.nationalmap.gov/v1
# Legacy (may return Access Denied): https://apps.nationalmap.gov/epqs/pqs.php
# USGS_3DEP_LIDAR_EXPLORER=https://apps.nationalmap.gov/lidar-explorer
# USGS_3DEP_EPT_INDEX=https://usgs.entwine.io
# USGS_3DEP_S3_PUBLIC=s3://usgs-lidar-public
# USGS_3DEP_S3_REQUESTER_PAYS=s3://usgs-lidar

# ─── Gemini (server-side AI for POST /api/ai/gemini when VITE_USE_SERVER_AI=true) ─
# Required for DMRV AI helpers, DPAL Assistant enrichment, and other /api/ai/gemini callers.
# Copy the same key you use on Railway production, or create one at https://aistudio.google.com/apikey
# GEMINI_API_KEY=""
# Optional default model (fallback chain also tries gemini-2.5-flash, gemini-2.0-flash):
# GEMINI_MODEL=gemini-2.5-flash

# ─── Climatiq carbon calculation engine (server-only; never VITE_*) ───────────
# Rotate keys in the Climatiq dashboard if exposed. Bearer token stays on Railway/backend only.
CLIMATIQ_API_KEY=""
CLIMATIQ_DATA_VERSION="^21"

# ─── FloodGuard — water-level adapter (Stage 12E, optional) ─────────────────
# FLOODGUARD_LIVE_WATER_LEVEL_ENABLED=true
# FLOODGUARD_WATER_LEVEL_PROVIDER=synthetic
