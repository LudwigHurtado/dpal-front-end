# Copy to .env and fill in your Supabase credentials

# ─── Supabase Postgres (from Supabase dashboard → Settings → Database) ───────
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ─── Supabase project credentials ────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
SUPABASE_ANON_KEY="[ANON_KEY]"

# ─── Supabase Storage bucket for attachments ─────────────────────────────────
SUPABASE_STORAGE_BUCKET="help-attachments"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS — comma-separated list of allowed origins ──────────────────────────
# Backend accepts either FRONTEND_ORIGIN or CORS_ORIGINS (both are supported).
# Note: dpal-enterprise-dashboard.vercel.app and dpal-front-end.vercel.app are
# always allowed by built-in defaults in src/index.ts.
FRONTEND_ORIGIN="http://localhost:5173,http://localhost:3000"
# CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Admin secret (simple bearer token for admin endpoints in dev) ───────────
ADMIN_SECRET="change-this-in-production"

# ─── DPAL auth (JWT access + refresh tokens in PostgreSQL) ───────────────────
# Required for /api/auth/register|login|refresh|me|presence — use a long random string.
JWT_SECRET="replace-with-32-plus-random-chars-minimum"

# Optional: default balances for new accounts (see src/config/starterDefaults.ts)
# DPAL_STARTER_CREDITS=1000
# DPAL_STARTER_COINS=500
# DPAL_STARTER_HERO_CREDITS=2745
# DPAL_STARTER_DPAL_COINS=100
# DPAL_STARTER_REPUTATION=10
# DPAL_STARTER_TRUST=50
