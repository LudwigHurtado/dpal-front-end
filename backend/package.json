{
  "name": "dpal-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "npx prisma db push --schema=./prisma/schema.prisma && node dist/index.js",
    "smoke:carb": "npm run build && node dist/scripts/checkCarbLiveHealth.js",
    "smoke:forest-integrity": "npm run build && node dist/scripts/smokeForestIntegrity.js",
    "smoke:report-reader": "npx tsx src/scripts/smokeReportReaderChat.ts",
    "smoke:env-intel-sources": "npm run build && node dist/scripts/smokeSourceRegistry.js",
    "smoke:provider-execution": "npx tsx src/scripts/smokeProviderExecution.ts",
    "smoke:evidence-packets": "npx tsx src/scripts/smokeEvidencePackets.ts",
    "smoke:evidence-packet-store": "npx tsx src/scripts/smokeEvidencePacketStore.ts",
    "smoke:accountability-profiles": "npx tsx src/scripts/smokeAccountabilityProfiles.ts",
    "test:plastic-watch": "npx tsx src/services/hyperspectral/plasticWatch.selftest.ts && npx tsx src/services/hyperspectral/plasticWatch.routeScan.selftest.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.20.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.46.2",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
