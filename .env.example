# Backend API (Railway). All /api/* requests go here; backend should use MongoDB (Railway MongoDB or Atlas).
VITE_API_BASE=https://web-production-a27b.up.railway.app

# Optional: Gemini AI (backend can also use its own key server-side).
# VITE_GEMINI_API_KEY=

# Optional: Brave Web Search token (used for live internet search only).
# VITE_BRAVE_SEARCH_API_KEY=

# Optional: Google Maps (Locator page live map + Places autocomplete).
# VITE_GOOGLE_MAPS_API_KEY=
# Optional local-only key for localhost dev (used before VITE_GOOGLE_MAPS_API_KEY when on localhost/127.0.0.1).
# Useful if production key is referrer-restricted and excludes localhost.
# VITE_GOOGLE_MAPS_API_KEY_LOCAL=

# Optional: Society Game Hub — each experience opens in a new tab when set.
# VITE_GAME_URL_INVESTIGATION_NETWORK=
# VITE_GAME_URL_INVESTIGATE_OBSERVE_INTELLIGENT=
# VITE_GAME_URL_BEACON_COMMUNITY=
# VITE_GAME_URL_CLEAN_ZONE_RESTORE_EARTH=
# VITE_GAME_URL_SAFE_REPORTING=
# VITE_GAME_URL_TAKE_THE_WALK_SHARE_MOMENT=
# VITE_GAME_URL_KITTY_COMFORT_VISITS=
# VITE_GAME_URL_SILENT_OBSERVER=
